{
  "compilerOptions": {
    "jsx": "react-jsx",  // Important pour React 17+ (évite d'importer React explicitement)
    "target": "ESNext",  // Ou ES2022, selon tes besoins
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,  // Active tous les checks stricts (recommandé)
    "esModuleInterop": true,  // Pour l'interopérabilité avec les modules CommonJS
    "skipLibCheck": true,  // Améliore la vitesse de compilation en évitant les vérifications de type des librairies
    "noUnusedLocals": true,  // Détecte les variables inutilisées
    "noUnusedParameters": true,  // Détecte les paramètres de fonction inutilisés
    "allowJs": true  // Permet d'inclure les fichiers JS si nécessaire
  },
  "include": [
    "src/**/*"  // Assure-toi d'inclure tous les fichiers nécessaires
  ],
  "exclude": [
    "node_modules",  // N'inclut pas les fichiers de node_modules
    "dist"           // N'inclut pas les fichiers compilés
  ]
}
